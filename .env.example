# Application
PORT=3001
NODE_ENV=development
APP_TIMEZONE=UTC

# CORS — URLs separadas por vírgula que têm permissão de acessar a API
# Exemplo: http://localhost:5173,https://meusite.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
# Connection String Standard (sem SRV - contorna bloqueio de DNS queries)
MONGODB_URI=mongodb://api_mata_mata:IQv1esRWilS9C2sC@ac-gx1aq0n-shard-00-00.4oeb5wx.mongodb.net:27017,ac-gx1aq0n-shard-00-01.4oeb5wx.mongodb.net:27017,ac-gx1aq0n-shard-00-02.4oeb5wx.mongodb.net:27017/mata-mata-bolao?ssl=true&authSource=admin&retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# External Football API (football-data.org v4 — free, supports WC 2026)
# Register for a free token at: https://www.football-data.org/client/register
EXTERNAL_FOOTBALL_API_BASE_URL=https://api.football-data.org/v4
EXTERNAL_FOOTBALL_API_KEY=your-token


# Sync Configuration
SYNC_CRON=0 */30 * * * *
